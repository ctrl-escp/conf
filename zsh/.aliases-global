# Prevent glob null results from showing up
setopt +o cshnullglob
setopt +o nomatch

# ====================================================================
# Basic Navigation & System
# ====================================================================
alias ls='ls --color=auto'
alias ll='ls -laFh'          # Your preferred detailed list format
alias l='ll -S'              # Sorted by size
alias lls='ls -aF'           # Wide list with hidden files and explicit kinds of files
alias restart='shutdown -r now'
alias reload='source ~/.zshrc'

# Optional modern alternatives (uncomment to use eza instead of ls)
# alias ll='eza -la --classify=always -h'   # eza equivalent of ls -laFh
# alias l='eza -la --classify=always -h -s size'  # eza sorted by size

# Optional modern cat with syntax highlighting (uncomment if you want it)
alias cat='bat --paging=never'           # bat without pager behavior
# alias bat='bat --paging=always'          # bat with pager (for long files)

# Quick navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ====================================================================
# Development Tools
# ====================================================================
# Git shortcuts (complement the oh-my-zsh git plugin)
alias gst='git status'
alias glog='git log --oneline --graph --decorate'

# Python shortcuts
alias py='python3'
alias serve='python3 -m http.server'

# Network utilities
alias myip='curl ipinfo.io/ip'